# ─────────────────────────────────────────────
#  AI Autoposting Agent - Environment Config
#  Copy this file to .env and fill in your keys
#  Run: python setup_check.py to verify
# ─────────────────────────────────────────────

# ── Anthropic (required) ──────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── TikTok Content Posting API ────────────────
# Get these from https://developers.tiktok.com
# Requires business account + API access approval (2-3 days)
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token

# ── App Config ────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Whisper Model ─────────────────────────────
# Options: tiny | base | small | medium | large-v3
# Recommendation: base (fast + accurate enough)
# large-v3 = best quality, needs ~10GB RAM
WHISPER_MODEL=base

# ── Clip Config ───────────────────────────────
MAX_CLIP_DURATION=90      # Max seconds per clip
MIN_CLIP_DURATION=15      # Min seconds per clip


# ── Watch Folder (optional) ───────────────────
# Running WITHOUT Docker: use a local path
# WATCH_FOLDER=./watch_inbox

# Running WITH Docker: use the container path
# WATCH_FOLDER=/app/watch_inbox
# The host folder is mapped via the volume in docker-compose.yml

# ── Scheduler ─────────────────────────────────
# These are defaults — you can also change them in the dashboard UI.
# Times are in the timezone set in the dashboard (default: Africa/Lagos)
# SCHEDULE_ENABLED=false
# SCHEDULE_DAILY_LIMIT=3
# SCHEDULE_TIMES=08:00,13:00,19:00
