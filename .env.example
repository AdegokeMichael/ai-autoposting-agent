# ─────────────────────────────────────────────────────
#  Brand Bade Poster — Environment Config
#  Copy to .env and fill in your keys
#  Run: python setup_check.py to verify
# ─────────────────────────────────────────────────────

# ── Anthropic (required) ──────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── App Config ────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Whisper Model ─────────────────────────────────────
# Options: tiny | base | small | medium | large-v3
WHISPER_MODEL=base

# ── Clip Config ───────────────────────────────────────
MAX_CLIP_DURATION=90
MIN_CLIP_DURATION=15

# ── Watch Folder (optional) ───────────────────────────
# Without Docker: WATCH_FOLDER=./watch_inbox
# With Docker:    WATCH_FOLDER=/app/watch_inbox
# WATCH_FOLDER=./watch_inbox

# ═══════════════════════════════════════════════════
#  PLATFORMS — add credentials for each you want to use
# ═══════════════════════════════════════════════════

# ── YouTube Shorts (easiest — instant setup) ──────────
# 1. console.cloud.google.com → Enable YouTube Data API v3
# 2. Create OAuth 2.0 credentials (Desktop app type)
# 3. Download client_secret JSON → set path below
# 4. Run: python cli.py youtube-auth  (one-time browser login)
YOUTUBE_CLIENT_SECRETS_FILE=./client_secret.json
YOUTUBE_TOKEN_FILE=./youtube_token.json
# YOUTUBE_CHANNEL_ID=UCxxxxxxx  (optional, for logging)

# ── Instagram Reels ───────────────────────────────────
# 1. Facebook Business account required
# 2. developers.facebook.com → Create app → Instagram Graph API
# 3. Get long-lived Page Access Token
# 4. Find your Instagram Business Account ID
# INSTAGRAM_ACCESS_TOKEN=your_token_here
# INSTAGRAM_ACCOUNT_ID=your_account_id_here
# INSTAGRAM_PUBLIC_BASE_URL=http://135.236.211.197:8000

# ── Facebook Reels ────────────────────────────────────
# Same Meta developer app as Instagram
# 1. Get long-lived Page Access Token
# 2. Find your Facebook Page ID
# FACEBOOK_ACCESS_TOKEN=your_token_here
# FACEBOOK_PAGE_ID=your_page_id_here
# FACEBOOK_PUBLIC_BASE_URL=http://135.236.211.197:8000

# ── TikTok (pending API review — 2-3 business days) ───
# 1. developers.tiktok.com → Create app → Content Posting API
# 2. Complete business verification
# 3. Get access token via OAuth
# TIKTOK_ACCESS_TOKEN=your_token_here
# TIKTOK_CLIENT_KEY=your_client_key
# TIKTOK_CLIENT_SECRET=your_client_secret

# ── Scheduler defaults ────────────────────────────────
# Configurable via the dashboard Settings tab
# SCHEDULE_ENABLED=false
# SCHEDULE_DAILY_LIMIT=3
# SCHEDULE_TIMES=08:00,13:00,19:00
